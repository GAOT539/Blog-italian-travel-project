<%- include('partials/header', { tituloPagina, rutaActiva }) %>

<section class="mb-10 gruppo-rivelazione">
  <p class="text-xs uppercase tracking-[0.35em] text-ciano-700">Il nostro team</p>
  <h1 class="mt-3 text-[2.15rem] sm:text-[2.9rem]">Chi Siamo</h1>
</section>

<section class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
  <% integrantes.forEach((integrante) => { %>
    <article class="gruppo-rivelazione tarjeta-dinamica p-6 text-center">
      <div class="mx-auto w-36 overflow-hidden rounded-full border border-ceniza-300/80 bg-ceniza-200 shadow-sm sm:w-40">
        <div class="aspect-square">
          <img
            src="<%= integrante.foto %>"
            alt="Foto di <%= integrante.nombre %>"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <h2 class="mt-5 text-[1.45rem] leading-tight"><%= integrante.nombre %></h2>
      <p class="mt-3 text-sm font-semibold uppercase tracking-[0.12em] text-ciano-700"><%= integrante.rol %></p>
    </article>
  <% }) %>
</section>

<%- include('partials/footer') %>
